# Clerk Authentication (REQUIRED)
# Get keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Database - PlanetScale MySQL (REQUIRED)
# Get connection string from: https://planetscale.com
DATABASE_URL="mysql://username:password@host.aws.planetscale.com/database?sslaccept=strict"

# Inngest Background Jobs (REQUIRED)
# Get event key from: https://app.inngest.com
INNGEST_EVENT_KEY=...
INNGEST_DEV_SERVER_URL=http://localhost:8288

# Google Gemini AI - Lead Scoring (REQUIRED)
# Get API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# Resend - Email Reply Detection (OPTIONAL)
# Get API key from: https://resend.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@convertlist.ai
RESEND_WEBHOOK_SECRET=whsec_...

# Instantly.ai - Cold Email Sending (OPTIONAL)
# Get API key from: https://instantly.ai
INSTANTLY_API_KEY=...

# Clearbit - Lead Enrichment (OPTIONAL)
# Get API key from: https://clearbit.com
CLEARBIT_API_KEY=...

# DodoPayments - Payment Processing (OPTIONAL)
# Get keys from: https://dodopayments.com
DODO_WEBHOOK_SECRET=...
DODO_PRICE_ID_PRO=price_pro_monthly
DODO_PRICE_ID_PRO_PLUS=price_pro_plus_monthly
DODO_PRICE_ID_LAUNCH=price_launch

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
