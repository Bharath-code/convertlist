// Learn about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  email     String     @unique
  plan      Plan       @default(FREE)
  planExpiry DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  waitlists Waitlist[]
  
  // Multi-Product Intelligence fields (M1)
  productHistory        String?
  crossProductBehavior  String?
  superUserScore        Float?
  lifetimeValuePrediction Float?
}

model Waitlist {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  totalLeads     Int      @default(0)
  processedLeads Int      @default(0)
  status         ProcessingStatus @default(PENDING)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  leads          Lead[]
  
  // Launch Day Command Center fields (L1)
  launchReadinessScore   Float?
  recommendedLaunchDate   DateTime?
  engagementHeatmap      String?
  seasonalityData         String?
  sequences      Sequence[]

  // Dynamic Pricing Intelligence fields (P1)
  recommendedPricePoint  String?
  priceConfidence       Float?
  willingnessToPayScore Float?
  discountStrategy      String?
}

model Lead {
  id           String    @id @default(cuid())
  waitlistId  String
  waitlist     Waitlist @relation(fields: [waitlistId], references: [id], onDelete: Cascade)
  email       String
  name        String?
  company     String?
  signupNote  String?
  source      String?
  createdAt   DateTime?
  importedAt  DateTime  @default(now())
  score       Int?
  confidence  Confidence?
  reason      String?
  segment     Segment?
  status      LeadStatus @default(UNCONTACTED)
  sequenceId  String?
  sequence    Sequence? @relation(fields: [sequenceId], references: [id])
  replyForwarder String? @unique
  statusHistory LeadStatusHistory[]
  updatedAt   DateTime  @updatedAt

  // Enrichment fields
  linkedinUrl           String?
  companySize          String?
  techStack            String?
  fundingStatus        String?
  twitterFollowers     Int?
  githubActivity      Int?
  socialProofScore     Int?
  enrichedAt           DateTime?
  enrichmentConfidence Float?

  // Clustering fields
  useCaseCluster       String?
  painPointTribe       String?
  lookalikeGroupId     String?
  clusterConfidence    Float?

  // Demo script fields
  demoScript           String?
  featurePriority      String?
  objectionHandling    String?
  timelinePrediction   String?

  // Virality Score fields (V1)
  viralityScore        Int?
  sharePropensity      Float?
  networkReach         Int?
  advocatePotential    Float?

  // Competitor Cross-Reference fields (X1)
  detectedCompetitors String?
  competitorFeatures   String?
  switchingCost        String?
  competitorConfidence Float?

  // Referral Network Mapper fields (N1)
  relatedLeads         String?
  companyRelationships String?
  communityOverlap     String?
  influenceScore       Float?

  @@index([waitlistId])
  @@index([email])
}

model Sequence {
  id         String   @id @default(cuid())
  waitlistId String
  waitlist   Waitlist @relation(fields: [waitlistId], references: [id], onDelete: Cascade)
  name       String
  leads      Lead[]
  steps      SequenceStep[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([waitlistId])
}

model SequenceStep {
  id         String   @id @default(cuid())
  sequenceId String
  sequence   Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  order      Int
  subject    String
  body       String
  delayDays  Int      @default(0)
  variant    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sequenceId])
}

model LeadStatusHistory {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus LeadStatus?
  toStatus  LeadStatus
  changedAt DateTime @default(now())

  @@index([leadId])
}

model ConversionAnalytics {
  id               String   @id @default(cuid())
  signalType       String   // "domain_company", "domain_personal", "intent_urgent", "intent_specific", "source_referral", "recency_recent"
  signalValue      String   // e.g., "company", "personal", "urgent", "specific", "referral", "recent"
  totalLeads       Int      @default(0)
  convertedLeads   Int      @default(0)
  conversionRate   Float    @default(0)
  sampleSize       Int      @default(0)
  lastUpdatedAt    DateTime @default(now())
  createdAt        DateTime @default(now())

  @@unique([signalType, signalValue])
  @@index([signalType])
}

enum Plan {
  FREE
  STARTER
  PRO
  LAUNCH
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum Confidence {
  HIGH
  MEDIUM
  LOW
}

enum Segment {
  HOT
  WARM
  COLD
}

enum LeadStatus {
  UNCONTACTED
  CONTACTED
  REPLIED
  INTERESTED
  PAID
}
